# ─── Site ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Elena Vasquez Photography

# ─── Analytics (optional) ────────────────────────────────────────────────────
# Google Analytics 4 measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Contact Form — Resend (https://resend.com) ──────────────────────────────
# API key from the Resend dashboard
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Address that receives contact-form submissions
CONTACT_EMAIL_TO=hello@yourdomain.com

# Verified "From" domain on Resend  (must match a domain you own)
CONTACT_EMAIL_FROM=noreply@yourdomain.com
